# Configurações do Firebase Órbita
FIREBASE_API_KEY=SUA_API_KEY_AQUI
FIREBASE_AUTH_DOMAIN=seu-projeto.firebaseapp.com
FIREBASE_PROJECT_ID=seu-projeto
FIREBASE_STORAGE_BUCKET=seu-projeto.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789
FIREBASE_APP_ID=1:123456789:web:abcdef
FIREBASE_MEASUREMENT_ID=G-ABCDEF

# Leitura de fichas (módulo Ferida) — URL do serviço Python de OCR local
# (opcional; padrão http://127.0.0.1:5001 — ver /leitor-ficha/README.md)
LEITOR_FICHA_URL=http://127.0.0.1:5001

# Cofre de credenciais (módulo Acessos) — string longa e aleatória, usada
# para criptografar as senhas guardadas no banco (AES-256-GCM).
# Gere uma nova com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ⚠️ Se trocar essa chave depois de já ter senhas cadastradas, elas não
# poderão mais ser decifradas — guarde-a com segurança (ex.: cofre de senhas
# da instituição), fora do repositório.
ACESSOS_ENCRYPTION_KEY=GERE_UMA_CHAVE_ALEATORIA_E_COLOQUE_AQUI
